{
  "name": "ai-unified",
  "version": "1.0.0",
  "description": "A lightweight, zero-dependency unified AI API SDK for JavaScript/TypeScript. Call GPT, Claude, Gemini, and more with a single function.",
  "keywords": [
    "ai",
    "openai",
    "gpt",
    "claude",
    "gemini",
    "api",
    "sdk",
    "unified",
    "streaming",
    "typescript"
  ],
  "license": "MIT",
  "author": "haotokai.com",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "browser": "dist/index.browser.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.browser.mjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --out-dir dist",
    "build:browser": "tsup src/index.ts --format esm --dts --out-dir dist --env.NODE_ENV browser",
    "dev": "tsup src/index.ts --format cjs,esm --dts --out-dir dist --watch",
    "test": "node examples/basic.js",
    "prepublishOnly": "npm run build && npm run build:browser"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/haotokai/ai-unified-sdk"
  },
  "homepage": "https://github.com/haotokai/ai-unified-sdk#readme",
  "bugs": {
    "url": "https://github.com/haotokai/ai-unified-sdk/issues"
  }
}
